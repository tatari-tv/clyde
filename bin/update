#!/usr/bin/env bash
#
# bin/update - orchestrator for the dual-parser pricing refresh.
#
# Pipeline:
#   1. Fetch Anthropic's pricing.md (one HTTP request total).
#   2. Run two independent parsers on the same input:
#        bin/update.sh  - bash + awk
#        bin/update.py  - stdlib Python 3
#   3. Refuse to ship if their outputs disagree (semantic equality:
#      5 == 5.0).
#   4. Run three regression checks against the previous pricing.json:
#        a. No model that existed previously is now missing.
#        b. No per-model rate moves more than 5x in either direction.
#        c. Every rate is within absolute bounds [$0.001, $1000]/MTok.
#   5. Wrap the agreed pricing map with the v1 schema envelope and
#      write data/pricing.json plus data/pricing-page.sha256.
#
# Usage:
#   bin/update          - fetch, parse, validate, write
#   bin/update --dry    - fetch and validate but do not write any files
#
# This script is the only entrypoint the GitHub Actions cron calls;
# everything else (the awk parser, the Python parser, the regression
# checks) is invoked from here.

set -euo pipefail

PRICING_URL="https://platform.claude.com/docs/en/about-claude/pricing.md"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PRICING_FILE="$REPO_ROOT/data/pricing.json"
HASH_FILE="$REPO_ROOT/data/pricing-page.sha256"
SCHEMA_VERSION=1
MIN_LIBRARY_VERSION="0.1.0"

DRY_RUN=false
if [[ "${1:-}" == "--dry" ]]; then
    DRY_RUN=true
fi

DATA_VERSION="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

WORKDIR="$(mktemp -d)"
trap 'rm -rf "$WORKDIR"' EXIT

PAGE_FILE="$WORKDIR/pricing.md"
AWK_OUT="$WORKDIR/awk.json"
PY_OUT="$WORKDIR/py.json"
PRICING_MAP="$WORKDIR/pricing-map.json"
NEW_PRICING_FILE="$WORKDIR/pricing.json"

# -- Fetch ---------------------------------------------------------------
echo "Fetching pricing page from Anthropic..."
curl -sS --max-time 30 "$PRICING_URL" > "$PAGE_FILE"

if [[ ! -s "$PAGE_FILE" ]]; then
    echo "Error: empty response from $PRICING_URL" >&2
    exit 1
fi

# -- Run both parsers on the same input ---------------------------------
echo "Running bin/update.sh (awk parser)..."
"$REPO_ROOT/bin/update.sh" < "$PAGE_FILE" > "$AWK_OUT"

echo "Running bin/update.py (Python parser)..."
"$REPO_ROOT/bin/update.py" < "$PAGE_FILE" > "$PY_OUT"

# -- Cross-check ---------------------------------------------------------
# Structural equality: 5 == 5.0, so the awk parser emitting raw integer
# literals and the Python parser emitting float literals are treated as
# equivalent. The diff we print on disagreement names exactly which
# (model, field) pairs differ, so failure mode is debuggable.
echo "Cross-checking parser outputs..."
python3 - "$AWK_OUT" "$PY_OUT" <<'PYEOF'
import json
import sys

awk_out = json.load(open(sys.argv[1]))
py_out = json.load(open(sys.argv[2]))

if awk_out == py_out:
    sys.exit(0)

errors = []
all_ids = sorted(set(awk_out) | set(py_out))
for mid in all_ids:
    if mid not in awk_out:
        errors.append(f"  missing in awk:    {mid}")
        continue
    if mid not in py_out:
        errors.append(f"  missing in python: {mid}")
        continue
    a, p = awk_out[mid], py_out[mid]
    if a == p:
        continue
    fields = sorted(set(a) | set(p))
    for field in fields:
        av = a.get(field, "<missing>")
        pv = p.get(field, "<missing>")
        if av != pv:
            errors.append(f"  {mid}.{field}: awk={av} python={pv}")

print("Parsers disagree. Refusing to ship:", file=sys.stderr)
for e in errors:
    print(e, file=sys.stderr)
sys.exit(1)
PYEOF

# Both parsers agreed. Use the awk output as the canonical pricing map
# because its number formatting (5 vs 5.0) matches the historical shape
# of data/pricing.json byte-for-byte, minimising diff noise.
cp "$AWK_OUT" "$PRICING_MAP"

# -- Regression checks ---------------------------------------------------
echo "Running regression checks..."

# Check #3 (absolute bounds) runs unconditionally; it does not need a
# previous baseline.
python3 - "$PRICING_MAP" <<'PYEOF'
import json
import sys

LO = 0.001
HI = 1000.0

data = json.load(open(sys.argv[1]))
errors = []
for model, fields in data.items():
    for field, value in fields.items():
        if value < LO or value > HI:
            errors.append(f"  {model}.{field} = {value} (outside [{LO}, {HI}])")

if errors:
    print(
        "Regression check #3 failed: rate(s) outside absolute bounds [$0.001, $1000]/MTok",
        file=sys.stderr,
    )
    for e in errors:
        print(e, file=sys.stderr)
    sys.exit(1)
PYEOF

# Checks #1 (no models lost) and #2 (no >5x rate movement) compare
# against the existing data/pricing.json. On the very first run there
# is nothing to compare against, so we skip them.
if [[ -f "$PRICING_FILE" ]]; then
    python3 - "$PRICING_MAP" "$PRICING_FILE" <<'PYEOF'
import json
import sys

MAX_RATIO = 5.0

new = json.load(open(sys.argv[1]))
old_envelope = json.load(open(sys.argv[2]))
# Accept both the v1 schema (with the "pricing" key) and the legacy
# shape ({"pricing": {...}} but no schema_version) - serde and this
# script both treat them identically.
old = old_envelope.get("pricing", old_envelope)

# Check #1: no model that existed previously is now missing. New models
# added by Anthropic are fine; quietly losing a model is a strong
# signal that the parser dropped a row.
missing = sorted(set(old.keys()) - set(new.keys()))
if missing:
    print(
        "Regression check #1 failed: models present previously are missing now:",
        file=sys.stderr,
    )
    for m in missing:
        print(f"  {m}", file=sys.stderr)
    sys.exit(1)

# Check #2: no per-model rate moves by more than MAX_RATIO. This is the
# decimal-shift / unit-confusion guardrail. Real Anthropic price moves
# rarely exceed 2-3x in a single update; 5x is conservative enough to
# never trip on a genuine repricing while catching 100x parse errors.
shifts = []
for model in old.keys() & new.keys():
    for field in old[model].keys() & new[model].keys():
        old_v = old[model][field]
        new_v = new[model][field]
        if old_v <= 0 or new_v <= 0:
            continue
        ratio = max(old_v / new_v, new_v / old_v)
        if ratio > MAX_RATIO:
            shifts.append(
                f"  {model}.{field}: {old_v} -> {new_v} ({ratio:.2f}x)"
            )

if shifts:
    print(
        f"Regression check #2 failed: rate(s) moved more than {MAX_RATIO}x:",
        file=sys.stderr,
    )
    for s in shifts:
        print(s, file=sys.stderr)
    sys.exit(1)
PYEOF
fi

# -- Detect whether the pricing map actually changed --------------------
# We always run, but we only rewrite data/pricing.json (and bump
# data_version) when the new pricing map differs from what is already
# committed. Without this guard, every cron run would replace the file
# with the same prices and a fresh data_version timestamp, causing the
# workflow to open an empty PR every day. data/pricing-page.sha256 is
# always rewritten because it is a deterministic hash of the page bytes,
# so it never produces a spurious diff.
PRICING_CHANGED=true
if [[ -f "$PRICING_FILE" ]]; then
    if python3 - "$PRICING_MAP" "$PRICING_FILE" <<'PYEOF'
import json
import sys

new = json.load(open(sys.argv[1]))
old_envelope = json.load(open(sys.argv[2]))
old = old_envelope.get("pricing", old_envelope)
sys.exit(0 if new == old else 1)
PYEOF
    then
        PRICING_CHANGED=false
    fi
fi

# -- Wrap with v1 envelope (only when prices changed) -------------------
if [[ "$PRICING_CHANGED" == true ]]; then
    jq \
        --argjson schema_version "$SCHEMA_VERSION" \
        --arg data_version "$DATA_VERSION" \
        --arg min_library_version "$MIN_LIBRARY_VERSION" \
        '{schema_version: $schema_version, data_version: $data_version, min_library_version: $min_library_version, pricing: .}' \
        "$PRICING_MAP" > "$NEW_PRICING_FILE"
fi

PAGE_HASH="$(sha256sum "$PAGE_FILE" | cut -d' ' -f1)"

# -- Dry run short-circuit ----------------------------------------------
if [[ "$DRY_RUN" == true ]]; then
    echo ""
    if [[ "$PRICING_CHANGED" == true ]]; then
        echo "=== Dry run - would write data/pricing.json: ==="
        cat "$NEW_PRICING_FILE"
    else
        echo "=== Dry run - pricing unchanged, would NOT rewrite data/pricing.json ==="
    fi
    echo ""
    echo "SHA-256: $PAGE_HASH"
    exit 0
fi

# -- Write -------------------------------------------------------------
if [[ "$PRICING_CHANGED" == true ]]; then
    mv "$NEW_PRICING_FILE" "$PRICING_FILE"
    echo "Wrote $PRICING_FILE (data_version=$DATA_VERSION)"
else
    echo "Pricing unchanged - left $PRICING_FILE intact"
fi
echo "$PAGE_HASH" > "$HASH_FILE"
echo "Wrote $HASH_FILE"

if git -C "$REPO_ROOT" rev-parse --git-dir >/dev/null 2>&1; then
    echo ""
    echo "=== Changes ==="
    git -C "$REPO_ROOT" diff --stat data/ || true
fi

echo ""
echo "Done. Review the changes, then commit and cut a release."
