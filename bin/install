#!/usr/bin/env bash
# bin/install - Build and install ccu locally
#
# Pricing data is now owned by the claude-pricing library (auto-refreshed
# via a 24h-cached Pages feed). Local installs only need to compile.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

echo "=== Building and installing ccu ==="
cargo install --path "$REPO_ROOT"
